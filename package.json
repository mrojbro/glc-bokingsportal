{
  "name": "glc-bokingsportal",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "node scripts/dev-hub.mjs",
    "dev:fast": "node scripts/dev-hub.mjs --skip-build",
    "ports:free": "node scripts/free-ports.mjs",
    "dev:vite": "node scripts/dev.mjs",
    "dev:portal": "npm run dev -w @glc-bokingsportal/portal",
    "dev:kaka": "npm run dev -w @glc-bokingsportal/kaka",
    "dev:ewerman": "npm run dev -w @glc-bokingsportal/ewerman",
    "dev:lars-goran": "npm run dev -w @glc-bokingsportal/lars-goran",
    "dev:coop-matkassar": "npm run dev -w @glc-bokingsportal/coop-matkassar",
    "dev:coop-frukt": "npm run dev -w @glc-bokingsportal/coop-frukt",
    "dev:coop-tomgods": "npm run dev -w @glc-bokingsportal/coop-tomgods",
    "dev:comforta": "npm run dev -w @glc-bokingsportal/comforta",
    "build": "node scripts/build-all.mjs",
    "preview": "node scripts/preview-local.mjs"
  }
}
